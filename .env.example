# Copy this to .env (not committed) and set the host path where evidence
# files (avatars/exhibit photos/exhibit documents) should live on disk.
#
# Windows/Docker Desktop example:
#   POLARIS_DATA_PATH=C:/polaris_data
#
# Unraid example:
#   POLARIS_DATA_PATH=/mnt/user/appdata/polaris/data
POLARIS_DATA_PATH=./polaris_data

# Secret used to HMAC-sign case/exhibit history rows (see includes/integrity.php).
# Generate a real value with: openssl rand -hex 32
HISTORY_HMAC_KEY=change_me_hmac_key
